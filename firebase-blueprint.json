{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A blog post or portfolio item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "HTML or JSON content from editor" },
        "categoryIds": { "type": "array", "items": { "type": "string" } },
        "mediaUrls": { "type": "array", "items": { "type": "string" } },
        "date": { "type": "string", "format": "date-time", "description": "The release date displayed to users" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "categoryIds", "date"]
    },
    "Category": {
      "title": "Category",
      "description": "A blog category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bgColor": { "type": "string", "description": "Hex background color" },
        "textColor": { "type": "string", "description": "Hex text color" }
      },
      "required": ["name", "bgColor", "textColor"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "Newsletter subscriber",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "topicIds": { "type": "array", "items": { "type": "string" } },
        "subscribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "topicIds"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories"
    },
    "/settings/{settingId}": {
      "schema": "object",
      "description": "Site-wide settings"
    },
    "/newsletter/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Collection of newsletter subscribers"
    }
  }
}
